++experiment2 = Experiment("KAN", "Circus", [6, 7, 8])
++rlexperiment1 = RLExperiment("MLP", "School", [3, 8, 3], "basic")
++rlexperiment2 = RLExperiment("KAN", "Claude HQ", [20, 22, 15], "advanced")
