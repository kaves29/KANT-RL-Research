++
++    def average_reward(self):
++        total = 0
++        counter = 0
++        for r in self.rewards:
++            total += r
++            counter += 1
++        return total / counter
++    
++    def summary(self):
++        print(f"Name: {self.name}, Environment: {self.environment}, Rewards: {self.rewards}, Average Reward: {self.average_reward()}")
